{% doc %}
  @prompt
    voglio icone di prodotti che ti indico cliccabil che rimandano a specifici prodotti, scorrimento da mobile?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-icons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-product-icons-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-product-icons-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-icons-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.icon_spacing }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
  }

  .ai-product-icon-item-{{ ai_gen_id }} {
    position: relative;
    flex-shrink: 0;
  }

  .ai-product-icon-link-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: {{ block.settings.icon_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-product-icon-link-{{ ai_gen_id }}:hover {
    transform: scale({{ block.settings.hover_scale }});
    box-shadow: 0 4px 12px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-product-icon-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-icon-label-{{ ai_gen_id }} {
    position: absolute;
    bottom: -24px;
    left: 50%;
    transform: translateX(-50%);
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    white-space: nowrap;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-product-icons-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-product-icons-container-{{ ai_gen_id }} {
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: {{ block.settings.icon_spacing | times: 0.7 }}px;
    }

    .ai-product-icon-link-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-product-icons-container-{{ ai_gen_id }} {
      flex-wrap: wrap;
    }
  }
{% endstyle %}

<div class="ai-product-icons-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-icons-wrapper-{{ ai_gen_id }}">
    <div class="ai-product-icons-container-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign image_key = 'product_' | append: i | append: '_image'
          assign label_key = 'product_' | append: i | append: '_label'
          assign show_label_key = 'show_label_' | append: i

          assign product = block.settings[product_key]
          assign custom_image = block.settings[image_key]
          assign label = block.settings[label_key]
          assign show_label = block.settings[show_label_key]
        %}

        {% if product != blank %}
          <div class="ai-product-icon-item-{{ ai_gen_id }}">
            <a
              href="{{ product.url }}"
              class="ai-product-icon-link-{{ ai_gen_id }}"
              aria-label="Vai a {{ product.title }}"
            >
              {% if custom_image != blank %}
                <img
                  src="{{ custom_image | image_url: width: 200 }}"
                  alt="{{ custom_image.alt | default: product.title | escape }}"
                  class="ai-product-icon-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% elsif product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 200 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  class="ai-product-icon-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-product-icon-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </a>

            {% if show_label and label != blank %}
              <div class="ai-product-icon-label-{{ ai_gen_id }}">
                {{ label }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

